# hype.efi build output (clang/lld -> x86_64-unknown-uefi)
*.o
*.obj
*.efi
*.lib
*.map
*.dll
*.pdb
build/
out/

# tools/make-usb-package.sh's generated output -- README.md and the
# .img/directory tree it builds are all regenerable, not source.
release/

# EDK2 guest firmware pipeline (separate build, plan.md §8)
edk2/Build/
edk2/Conf/
*.fd
*.rom
# ...except fw/'s own vendored OVMF blob (plan.md §7 -- "reuse a
# stripped EDK2/OVMF build as a vendored blob"), produced by
# tools/build-fw.sh, which *is* meant to be committed.
!fw/*.fd

# Disk images / test artifacts
*.img
*.qcow2
*.vhd
*.iso

# QEMU / debugging
*.pid
gdb.log

# Host-native unit test coverage runs (core/tests/run.sh), per-module
# binaries built without an extension (test_<module> -> from test_<module>.c)
*.profraw
*.profdata
*.gcda
*.gcno
core/tests/test_*
!core/tests/test_*.c

# Editor/OS cruft
.vscode/
.idea/
*.swp
.DS_Store
